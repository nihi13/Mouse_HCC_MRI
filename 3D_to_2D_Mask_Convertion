import pydicom
import numpy as np
from pathlib import Path
import matplotlib.pyplot as plt

def inspect_mask_file(mask_path):
    """
    Deep inspection of DICOM mask file to understand its structure
    """
    print("\n" + "="*70)
    print("DICOM MASK DEEP INSPECTION")
    print("="*70)
    
    mask_path = Path(mask_path)
    print(f"\nFile: {mask_path.name}")
    print(f"Size: {mask_path.stat().st_size / 1024:.2f} KB")
    
    try:
        ds = pydicom.dcmread(str(mask_path), force=True)
        print("\n--- DICOM METADATA ---")
        print(f"Transfer Syntax: {ds.file_meta.TransferSyntaxUID if hasattr(ds, 'file_meta') else 'Unknown'}")
        print(f"Modality: {ds.Modality if hasattr(ds, 'Modality') else 'Unknown'}")
        print(f"Patient ID: {ds.PatientID if hasattr(ds, 'PatientID') else 'Unknown'}")
        
        # Get pixel array
        pixel_array = ds.pixel_array
        print(f"\n--- PIXEL DATA ---")
        print(f"Shape: {pixel_array.shape}")
        print(f"Dtype: {pixel_array.dtype}")
        print(f"Min value: {pixel_array.min()}")
        print(f"Max value: {pixel_array.max()}")
        print(f"Mean value: {pixel_array.mean():.4f}")
        print(f"Unique values: {np.unique(pixel_array)[:20]}")  # Show first 20 unique values
        print(f"Total pixels: {pixel_array.size:,}")
        print(f"Non-zero pixels: {np.count_nonzero(pixel_array):,}")
        print(f"Non-zero percentage: {100 * np.count_nonzero(pixel_array) / pixel_array.size:.2f}%")
        
        # Check for specific DICOM attributes
        print(f"\n--- SPATIAL INFO ---")
        if hasattr(ds, 'ImagePositionPatient'):
            print(f"ImagePositionPatient: {ds.ImagePositionPatient}")
        if hasattr(ds, 'SliceLocation'):
            print(f"SliceLocation: {ds.SliceLocation}")
        if hasattr(ds, 'SpacingBetweenSlices'):
            print(f"SpacingBetweenSlices: {ds.SpacingBetweenSlices}")
        if hasattr(ds, 'SliceThickness'):
            print(f"SliceThickness: {ds.SliceThickness}")
        if hasattr(ds, 'PixelSpacing'):
            print(f"PixelSpacing: {ds.PixelSpacing}")
        
        # Check for multi-frame
        print(f"\n--- STRUCTURE ---")
        if hasattr(ds, 'NumberOfFrames'):
            print(f"Number of Frames: {ds.NumberOfFrames}")
        if hasattr(ds, 'PerFrameFunctionalGroupsSequence'):
            print(f"Has PerFrameFunctionalGroupsSequence: Yes ({len(ds.PerFrameFunctionalGroupsSequence)} frames)")
        
        # Analyze each slice if 3D
        if len(pixel_array.shape) == 3:
            print(f"\n--- PER-SLICE ANALYSIS ---")
            print(f"Total slices: {pixel_array.shape[0]}")
            non_empty_slices = []
            for i in range(pixel_array.shape[0]):
                slice_data = pixel_array[i]
                non_zero = np.count_nonzero(slice_data)
                if non_zero > 0:
                    non_empty_slices.append(i)
                    print(f"  Slice {i:3d}: {non_zero:6d} non-zero pixels, "
                          f"min={slice_data.min()}, max={slice_data.max()}, "
                          f"unique={len(np.unique(slice_data))}")
            
            if not non_empty_slices:
                print("   ALL SLICES ARE EMPTY (all zeros)!")
            else:
                print(f"\n  ✓ Found {len(non_empty_slices)} non-empty slices: {non_empty_slices}")
        
        # Try to visualize middle slice
        print(f"\n--- VISUALIZATION ---")
        if len(pixel_array.shape) == 3:
            mid_slice = pixel_array.shape[0] // 2
            slice_data = pixel_array[mid_slice]
        else:
            slice_data = pixel_array
        
        plt.figure(figsize=(12, 4))
        
        plt.subplot(1, 3, 1)
        plt.imshow(slice_data, cmap='gray')
        plt.title(f'Raw Mask Data\n(min={slice_data.min()}, max={slice_data.max()})')
        plt.colorbar()
        plt.axis('off')
        
        plt.subplot(1, 3, 2)
        plt.imshow(slice_data > 0, cmap='gray')
        plt.title(f'Binarized (>0)\n({np.count_nonzero(slice_data)} non-zero)')
        plt.axis('off')
        
        plt.subplot(1, 3, 3)
        plt.hist(slice_data.flatten(), bins=50, log=True)
        plt.title('Pixel Value Histogram (log scale)')
        plt.xlabel('Pixel Value')
        plt.ylabel('Count (log)')
        plt.grid(True, alpha=0.3)
        
        plt.tight_layout()
        output_path = f'mask_inspection_{mask_path.stem}.png'
        plt.savefig(output_path, dpi=150, bbox_inches='tight')
        print(f"Saved visualization: {output_path}")
        plt.show()
        
        # Check specific DICOM tags that might indicate the issue
        print(f"\n--- ADDITIONAL CHECKS ---")
        if hasattr(ds, 'RescaleIntercept'):
            print(f"RescaleIntercept: {ds.RescaleIntercept}")
        if hasattr(ds, 'RescaleSlope'):
            print(f"RescaleSlope: {ds.RescaleSlope}")
        if hasattr(ds, 'WindowCenter'):
            print(f"WindowCenter: {ds.WindowCenter}")
        if hasattr(ds, 'WindowWidth'):
            print(f"WindowWidth: {ds.WindowWidth}")
        if hasattr(ds, 'BitsAllocated'):
            print(f"BitsAllocated: {ds.BitsAllocated}")
        if hasattr(ds, 'BitsStored'):
            print(f"BitsStored: {ds.BitsStored}")
        if hasattr(ds, 'HighBit'):
            print(f"HighBit: {ds.HighBit}")
        
        print("\n" + "="*70)
        
        # DIAGNOSIS
        print("\n🔍 DIAGNOSIS:")
        if np.count_nonzero(pixel_array) == 0:
            print(" PROBLEM: Mask file contains ONLY ZEROS!")
            print("   Possible causes:")
            print("   1. Wrong file - this might not be a mask file")
            print("   2. Mask was saved incorrectly")
            print("   3. Mask data is stored in a different format")
            print("   4. Need to check the annotation/segmentation tool output")
        elif pixel_array.max() <= 1:
            print("  POTENTIAL ISSUE: Mask values are 0 or 1 (binary)")
            print("   This is actually fine, but might be hard to see")
            print("   The aligner should multiply by 255 for visibility")
        else:
            print("✓ Mask appears to have data")
        
        print("="*70 + "\n")
        
        return ds, pixel_array
        
    except Exception as e:
        print(f"\n ERROR reading file: {e}")
        import traceback
        traceback.print_exc()
        return None, None

def check_alternative_mask_formats(mask_folder):
    """
    Check if there are PNG or other mask formats in the folder
    """
    mask_folder = Path(mask_folder)
    print("\n" + "="*70)
    print("CHECKING FOR ALTERNATIVE MASK FORMATS")
    print("="*70)
    
    png_masks = list(mask_folder.glob("*.png"))
    npy_masks = list(mask_folder.glob("*.npy"))
    nifti_masks = list(mask_folder.glob("*.nii*"))
    
    print(f"\nFound in {mask_folder}:")
    print(f"  PNG files: {len(png_masks)}")
    print(f"  NPY files: {len(npy_masks)}")
    print(f"  NIfTI files: {len(nifti_masks)}")
    
    if png_masks:
        print(f"\n📁 PNG masks found:")
        for png in png_masks[:5]:
            print(f"  - {png.name}")
    
    if npy_masks:
        print(f"\n📁 NPY masks found:")
        for npy in npy_masks[:5]:
            print(f"  - {npy.name}")
    
    print("="*70 + "\n")

def main():
    # Inspect the mask file
    MASK_FILE = "path_to_file"
    
