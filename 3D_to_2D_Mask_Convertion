import pydicom
import matplotlib.pyplot as plt

def verify_overlay(mri_path, mask_path, alpha=0.35):
    mri_ds  = pydicom.dcmread(mri_path, force=True)
    mask_ds = pydicom.dcmread(mask_path, force=True) 

    mri_img  = mri_ds.pixel_array.astype(float)
    mask_img = mask_ds.pixel_array.astype(float)

    mri_norm = (mri_img - mri_img.min()) / (mri_img.max() - mri_img.min() + 1e-8)

    fig, axes = plt.subplots(1, 3, figsize=(14, 5))
    axes[0].imshow(mri_norm, cmap='gray'); axes[0].set_title('MRI')
    axes[1].imshow(mask_img, cmap='hot');  axes[1].set_title('Mask')
    axes[2].imshow(mri_norm, cmap='gray')
    axes[2].imshow(mask_img > 0, cmap='Reds', alpha=alpha)
    axes[2].set_title('Overlay')

    for ax in axes: ax.axis('off')
    plt.tight_layout()
    plt.savefig('overlay_check.png', dpi=150)
    plt.show()

