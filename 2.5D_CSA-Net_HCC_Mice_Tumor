# LOAD AUTOENCODER WEIGHTS
# ===============================
def load_autoencoder_weights(model, autoencoder_path, device='cuda'):
    """Load pretrained T1 autoencoder encoder weights into CSANet"""
    if not os.path.exists(autoencoder_path):
        print(f"⚠ Autoencoder checkpoint not found: {autoencoder_path}")
        return model
    
    print("\n" + "="*70)
    print("LOADING T1 AUTOENCODER WEIGHTS")
    print("="*70)
    print(f"Loading from: {autoencoder_path}")
    
    autoencoder_state = torch.load(autoencoder_path, map_location=device)
    encoder_weights = {}
    
    # Extract encoder weights
    for key, value in autoencoder_state.items():
        if key.startswith('encoder.'):
            new_key = key.replace('encoder.', '')
            encoder_weights[new_key] = value
    
    # Load into hybrid model
    hybrid_encoder = model.transformer.embeddings.hybrid_model
    missing_keys, unexpected_keys = hybrid_encoder.load_state_dict(encoder_weights, strict=False)
    
    print(f"✓ Loaded {len(encoder_weights) - len(missing_keys)} encoder weights")
    print(f"✓ Encoder unfrozen for continued learning")
    print("="*70 + "\n")
    
    return model

# ===============================
# TRAINING FUNCTION
# ===============================
def train_csanet(model, train_loader, val_loader, device, config):
    print("\n" + "="*70)
    print("TRAINING CSANet WITH T1 AUTOENCODER")
    print("="*70)
    
    class_weights = torch.tensor([1.0, 100.0], device=device)
    criterion_ce = nn.CrossEntropyLoss(weight=class_weights)
    criterion_focal = FocalLoss(alpha=10, gamma=3)
    optimizer = optim.Adam(model.parameters(), lr=config.BASE_LR, weight_decay=config.WEIGHT_DECAY)
    scheduler = optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='max', factor=0.7, patience=8)
    
    best_dice = 0.0
    train_losses, val_losses, dice_scores = [], [], []
    metrics_calculator = SegmentationMetrics()
    patience_counter = 0
    
    for epoch in range(config.TOTAL_EPOCHS):
        # Training
        model.train()
        running_loss = 0.0
        
        for batch in train_loader:
            img_prev = batch["img_prev"].to(device)
            img_center = batch["img_center"].to(device)
            img_next = batch["img_next"].to(device)
            masks = batch["mask"].to(device)

            outputs = model(img_prev, img_center, img_next)
            loss_ce = criterion_ce(outputs, masks.squeeze(1).long())
            loss_focal = criterion_focal(outputs, masks.squeeze(1).long())
            loss = 0.3 * loss_ce + 0.7 * loss_focal

            optimizer.zero_grad()
            loss.backward()
            torch.nn.utils.clip_grad_norm_(model.parameters(), config.GRAD_CLIP_NORM)
            optimizer.step()

            running_loss += loss.item()

        avg_train_loss = running_loss / len(train_loader)
        train_losses.append(avg_train_loss)

        # Validation
        model.eval()
        val_loss = 0.0
        val_dice_list = []
        
        with torch.no_grad():
            for batch in val_loader:
                val_img_prev = batch["img_prev"].to(device)
                val_img_center = batch["img_center"].to(device)
                val_img_next = batch["img_next"].to(device)
                val_masks = batch["mask"].to(device)

                val_outputs = model(val_img_prev, val_img_center, val_img_next)
                v_loss = 0.3 * criterion_ce(val_outputs, val_masks.squeeze(1).long()) + \
                        0.7 * criterion_focal(val_outputs, val_masks.squeeze(1).long())

                val_loss += v_loss.item()
                pred = torch.argmax(val_outputs, dim=1)
                
                for i in range(val_masks.shape[0]):
                    dice = metrics_calculator.dice_score(
                        val_masks[i].cpu().numpy().squeeze(),
                        pred[i].cpu().numpy()
                    )
                    val_dice_list.append(dice)

        avg_val_loss = val_loss / len(val_loader)
        avg_dice = np.mean(val_dice_list)
        val_losses.append(avg_val_loss)
        dice_scores.append(avg_dice)
        
        print(f"Epoch {epoch+1:3d} | Train: {avg_train_loss:.6f} | Val: {avg_val_loss:.6f} | Dice: {avg_dice:.6f}")
        
        scheduler.step(avg_dice)
        
        # Save best model
        if avg_dice > best_dice:
            best_dice = avg_dice
            patience_counter = 0
            torch.save(model.state_dict(), config.CSANET_SAVE_PATH)
            print(f"   ✓ Best Dice: {best_dice:.6f} - Saved!")
            
            # Generate overlay visualizations for best model
            if epoch % 20 == 0:  # Every 20 epochs
                generate_overlay_visualizations(model, val_loader, device, config, epoch)
        else:
            patience_counter += 1
            if patience_counter >= config.PATIENCE:
                print(f"\n⚠ No improvement for {config.PATIENCE} epochs - stopping")
                break
    
    print("\n" + "="*70)
    print("TRAINING COMPLETE!")
    print("="*70)
    print(f"Best Dice: {best_dice:.6f}")
    print("="*70 + "\n")
    
    return train_losses, val_losses, dice_scores

def generate_overlay_visualizations(model, val_loader, device, config, epoch=None):
    """Generate overlay visualizations during/after training"""
    model.eval()
    
    all_images = []
    all_gt_masks = []
    all_pred_masks = []
    
    with torch.no_grad():
        for batch in val_loader:
            img_center = batch["img_center"].to(device)
            img_prev = batch["img_prev"].to(device)
            img_next = batch["img_next"].to(device)
            masks = batch["mask"].to(device)
            
            outputs = model(img_prev, img_center, img_next)
            preds = torch.argmax(outputs, dim=1)
            
            all_images.extend([img for img in img_center])
            all_gt_masks.extend([mask.squeeze() for mask in masks])
            all_pred_masks.extend([pred for pred in preds])
            
            if len(all_images) >= 8:  # Get enough samples
                break
    
    # Simple overlay
    if epoch is not None:
        save_path = os.path.join(config.OVERLAYS_DIR, f'overlay_epoch_{epoch:04d}.png')
    else:
        save_path = os.path.join(config.OVERLAYS_DIR, 'overlay_final.png')
    
    OverlayVisualization.create_overlay_comparison(
        all_images[:6], all_gt_masks[:6], all_pred_masks[:6], save_path, epoch
    )
    
    # Detailed overlay
    if epoch is None:  # Only for final
        detailed_path = os.path.join(config.OVERLAYS_DIR, 'overlay_detailed_final.png')
        OverlayVisualization.create_detailed_overlay(
            all_images, all_gt_masks, all_pred_masks, detailed_path
        )

