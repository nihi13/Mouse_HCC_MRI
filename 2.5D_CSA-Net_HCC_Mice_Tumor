            axes[1, i].set_title('Ground Truth', fontsize=11)
            axes[1, i].axis('off')
            
            # Row 3: Prediction overlay (Green)
            axes[2, i].imshow(img, cmap='gray')
            masked_pred = np.ma.masked_where(pred == 0, pred)
            axes[2, i].imshow(masked_pred, cmap='Greens', alpha=0.5)
            axes[2, i].set_title(f'Prediction\nDice: {dice:.3f}', fontsize=11)
            axes[2, i].axis('off')
        
        title = f'Overlay Comparison - Epoch {epoch}' if epoch else 'Final Overlay Comparison'
        plt.suptitle(title, fontsize=14, fontweight='bold')
        plt.tight_layout()
        plt.savefig(save_path, dpi=200, bbox_inches='tight')
        plt.close()
        
    @staticmethod
    def create_detailed_overlay(images, gt_masks, pred_masks, save_path):
        """Create detailed overlay with difference map"""
        n_samples = min(8, len(images))
        fig = plt.figure(figsize=(24, n_samples * 3))
        gs = fig.add_gridspec(n_samples, 4, hspace=0.3, wspace=0.2)
        
        for i in range(n_samples):
            img = images[i][0].cpu().numpy() if torch.is_tensor(images[i]) else images[i][0]
            gt = gt_masks[i].cpu().numpy() if torch.is_tensor(gt_masks[i]) else gt_masks[i]
            pred = pred_masks[i].cpu().numpy() if torch.is_tensor(pred_masks[i]) else pred_masks[i]
            
            # Calculate metrics
            metrics = SegmentationMetrics.compute_all_metrics(gt, pred)
            
            # Column 1: Original
            ax1 = fig.add_subplot(gs[i, 0])
            ax1.imshow(img, cmap='gray')
            ax1.set_title(f'Sample {i+1}', fontsize=10, fontweight='bold')
            ax1.axis('off')
            
            # Column 2: GT Overlay (Red)
            ax2 = fig.add_subplot(gs[i, 1])
            ax2.imshow(img, cmap='gray')
            masked_gt = np.ma.masked_where(gt == 0, gt)
            ax2.imshow(masked_gt, cmap='Reds', alpha=0.5)
            ax2.set_title('Ground Truth', fontsize=10)
            ax2.axis('off')
            
            # Column 3: Pred Overlay (Green)
            ax3 = fig.add_subplot(gs[i, 2])
            ax3.imshow(img, cmap='gray')
            masked_pred = np.ma.masked_where(pred == 0, pred)
            ax3.imshow(masked_pred, cmap='Greens', alpha=0.5)
            ax3.set_title('Prediction', fontsize=10)
            ax3.axis('off')
            
            # Column 4: Difference Map
            ax4 = fig.add_subplot(gs[i, 3])
            ax4.imshow(img, cmap='gray')
            
            # TP=Green, FN=Red, FP=Blue
            diff_rgb = np.zeros((*pred.shape, 3))
            gt_bool = gt > 0.5
            pred_bool = pred > 0.5
            diff_rgb[gt_bool & pred_bool] = [0, 1, 0]      # TP - Green
            diff_rgb[gt_bool & ~pred_bool] = [1, 0, 0]     # FN - Red
            diff_rgb[~gt_bool & pred_bool] = [0, 0.5, 1]   # FP - Blue
            
            mask = (gt_bool | pred_bool).astype(bool)
            diff_rgb_masked = np.ma.masked_where(~np.stack([mask]*3, axis=-1), diff_rgb)
            ax4.imshow(diff_rgb_masked, alpha=0.6)
            ax4.set_title(f'Dice: {metrics["dice"]:.3f} | IoU: {metrics["iou"]:.3f}', fontsize=9)
            ax4.axis('off')
        
        fig.text(0.5, 0.02,
                '● Green = True Positive | ● Red = False Negative | ● Blue = False Positive',
                ha='center', fontsize=12, fontweight='bold',
                bbox=dict(boxstyle='round', facecolor='wheat', alpha=0.8))
        
        plt.suptitle('Detailed Overlay Analysis', fontsize=16, fontweight='bold', y=0.995)
        plt.savefig(save_path, dpi=200, bbox_inches='tight')
        plt.close()

