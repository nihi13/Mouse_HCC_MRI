def main():
    print("\n" + "="*70)
    print("CSANet Training with T1 Autoencoder")
    print("R50-B16 Architecture - 2.5D")
    print("="*70)
    
    device = config.DEVICE
    print(f"\nDevice: {device}")
    print(f"Output Directory: {config.OUTPUT_BASE}")
    
    # Initialize model
    print("\n" + "="*70)
    print("INITIALIZING R50-B16 ARCHITECTURE")
    print("="*70)
    config_model = configs.get_r50_b16_config()
    model = ViT_seg(config_model, img_size=(256, 256), num_classes=config_model.n_classes).to(device)
    print("✓ Model initialized\n")
    
    # Load T1 autoencoder weights
    model = load_autoencoder_weights(model, config.AUTOENCODER_CHECKPOINT, device)
    
    # Augmentations
    train_transforms = Compose([
        RandFlipd(keys=["img_prev", "img_center", "img_next", "mask"], prob=0.5, spatial_axis=1),
        RandGaussianNoised(keys=["img_prev", "img_center", "img_next"], prob=0.5, std=0.01),
        RandGaussianSmoothd(keys=["img_prev", "img_center", "img_next"], prob=0.3, sigma_x=(0.5, 1.0)),
        EnsureTyped(keys=["img_prev", "img_center", "img_next", "mask"]),
        RandHistogramShiftd(keys=["img_prev", "img_center", "img_next"], num_control_points=10, prob=0.5),
        RandAdjustContrastd(keys=["img_prev", "img_center", "img_next"], prob=0.5, gamma=(0.5, 4.5)),
    ])
    
    val_transforms = Compose([
        EnsureTyped(keys=["img_prev", "img_center", "img_next", "mask"]),
    ])
    
    # Load datasets
    print("Loading datasets...")
    train_dataset_A = CSANet25DDataset(config.TRAIN_DICOM_DIR, config.TRAIN_MASK_DIR_A, transforms=train_transforms)
    train_dataset_B = CSANet25DDataset(config.TRAIN_DICOM_DIR, config.TRAIN_MASK_DIR_B, transforms=train_transforms)
    val_dataset = CSANet25DDataset(config.VAL_DICOM_DIR, config.VAL_MASK_DIR, transforms=val_transforms)
    
    # Combine datasets
    datasets_to_combine = []
    if len(train_dataset_A) > 0:
        datasets_to_combine.append(train_dataset_A)
    if len(train_dataset_B) > 0:
        datasets_to_combine.append(train_dataset_B)
    
    train_dataset = datasets_to_combine[0] if len(datasets_to_combine) == 1 else ConcatDataset(datasets_to_combine)
    
    train_loader = DataLoader(train_dataset, batch_size=config.BATCH_SIZE, shuffle=True)
    val_loader = DataLoader(val_dataset, batch_size=config.BATCH_SIZE, shuffle=False)
    
    print(f"\n✓ Training: {len(train_dataset)} samples")
    print(f"✓ Validation: {len(val_dataset)} samples")
    
    # Train
    train_losses, val_losses, dice_scores = train_csanet(model, train_loader, val_loader, device, config)
    
    # Save training curves
    plt.figure(figsize=(15, 5))
    plt.subplot(1, 3, 1)
    plt.plot(train_losses, label='Train')
    plt.plot(val_losses, label='Val')
    plt.xlabel('Epoch')
    plt.ylabel('Loss')
    plt.legend()
    plt.title('Loss Curves')
    plt.grid(alpha=0.3)
    
    plt.subplot(1, 3, 2)
    plt.plot(dice_scores)
    plt.xlabel('Epoch')
    plt.ylabel('Dice Score')
    plt.title('Dice Score Progress')
    plt.grid(alpha=0.3)
    
    plt.subplot(1, 3, 3)
    plt.plot(np.array(val_losses) - np.array(train_losses))
    plt.axhline(0, color='red', linestyle='--', alpha=0.5)
    plt.xlabel('Epoch')
    plt.ylabel('Generalization Gap')
    plt.title('Val Loss - Train Loss')
    plt.grid(alpha=0.3)
    
    plt.tight_layout()
    plt.savefig(os.path.join(config.PLOTS_DIR, 'training_curves.png'), dpi=300)
    plt.close()
    
    # Load best model and generate final visualizations
    model.load_state_dict(torch.load(config.CSANET_SAVE_PATH))
    generate_overlay_visualizations(model, val_loader, device, config, epoch=None)
    
    # Save metrics
    np.save(os.path.join(config.METRICS_DIR, 'train_losses.npy'), train_losses)
    np.save(os.path.join(config.METRICS_DIR, 'val_losses.npy'), val_losses)
    np.save(os.path.join(config.METRICS_DIR, 'dice_scores.npy'), dice_scores)
    
    print(f"\n✓ All outputs saved to: {config.OUTPUT_BASE}")
    print("="*70)

if __name__ == "__main__":
    main()
