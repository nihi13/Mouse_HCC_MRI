class SegmentationMetrics:
    """Comprehensive metrics for medical image segmentation"""
    
    @staticmethod
    def dice_score(y_true, y_pred, smooth=1e-6):
        intersection = (y_true * y_pred).sum()
        dice = (2. * intersection + smooth) / (y_true.sum() + y_pred.sum() + smooth)
        return dice
    
    @staticmethod
    def iou_score(y_true, y_pred, smooth=1e-6):
        intersection = (y_true * y_pred).sum()
        union = y_true.sum() + y_pred.sum() - intersection
        iou = (intersection + smooth) / (union + smooth)
        return iou
    
    @staticmethod
    def hausdorff_distance(y_true, y_pred):
        try:
            y_true_points = np.argwhere(y_true > 0.5)
            y_pred_points = np.argwhere(y_pred > 0.5)
            
            if len(y_true_points) == 0 or len(y_pred_points) == 0:
                return 0.0
            
            hd = max(directed_hausdorff(y_true_points, y_pred_points)[0],
                    directed_hausdorff(y_pred_points, y_true_points)[0])
            return hd
        except:
            return 0.0
    
    @staticmethod
    def sensitivity_specificity(y_true, y_pred):
        tp = (y_true * y_pred).sum()
        fn = (y_true * (1 - y_pred)).sum()
        tn = ((1 - y_true) * (1 - y_pred)).sum()
        fp = ((1 - y_true) * y_pred).sum()
        
        sensitivity = tp / (tp + fn + 1e-6)
        specificity = tn / (tn + fp + 1e-6)
        precision = tp / (tp + fp + 1e-6)
        
        return sensitivity, specificity, precision
    
    @staticmethod
    def compute_all_metrics(y_true, y_pred):
        dice = SegmentationMetrics.dice_score(y_true, y_pred)
        iou = SegmentationMetrics.iou_score(y_true, y_pred)
        hd = SegmentationMetrics.hausdorff_distance(y_true, y_pred)
        sens, spec, prec = SegmentationMetrics.sensitivity_specificity(y_true, y_pred)
        
        return {
            'dice': float(dice),
            'iou': float(iou),
            'hausdorff': float(hd),
            'sensitivity': float(sens),
            'specificity': float(spec),
            'precision': float(prec)
        }

