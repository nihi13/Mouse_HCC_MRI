class CSANet25DDataset(Dataset):
    def __init__(self, dicom_dir, mask_dir, target_size=(256, 256), transforms=None):
        self.dicom_dir = dicom_dir
        self.mask_dir = mask_dir
        self.target_size = target_size
        self.transforms = transforms

        if not os.path.exists(dicom_dir) or not os.path.exists(mask_dir):
            self.common_stems = []
            self.dicom_files = []
            self.mask_files = []
            return

        dicom_files = sorted([f for f in os.listdir(dicom_dir) if f.lower().endswith(".dcm")])
        mask_files = sorted([f for f in os.listdir(mask_dir) if f.lower().endswith((".png", ".dcm"))])

        dicom_stems = {os.path.splitext(f)[0]: f for f in dicom_files}
        mask_stems = {os.path.splitext(f)[0]: f for f in mask_files}

        self.common_stems = sorted(list(dicom_stems.keys() & mask_stems.keys()))
        self.dicom_files = [dicom_stems[s] for s in self.common_stems]
        self.mask_files = [mask_stems[s] for s in self.common_stems]

        print(f"   Found {len(self.common_stems)} matched pairs")

    def __len__(self):
        return max(0, len(self.common_stems) - 2)

    def __getitem__(self, idx):
        actual_idx = idx + 1
        
        img_prev = self._pad_or_resize(self._load_dicom(self.common_stems[actual_idx - 1]))
        img_center = self._pad_or_resize(self._load_dicom(self.common_stems[actual_idx]))
        img_next = self._pad_or_resize(self._load_dicom(self.common_stems[actual_idx + 1]))
        mask = self._pad_or_resize(self._load_mask(self.common_stems[actual_idx]))
        
        data_dict = {
            "img_prev": img_prev,
            "img_center": img_center,
            "img_next": img_next,
            "mask": mask,
        }
        
        if self.transforms:
            data_dict = self.transforms(data_dict)
        
        return data_dict

    def _load_dicom(self, stem):
        path = os.path.join(self.dicom_dir, stem + ".dcm")
        try:
            dcm = pydicom.dcmread(path)
        except:
            dcm = pydicom.dcmread(path, force=True)
        img = dcm.pixel_array.astype(np.float32)
        
        # Z-Score + FBS Normalization
        img_mean = np.mean(img)
        img_std = np.std(img)
        if img_std > 0:
            img = (img - img_mean) / img_std
        
        img_min = np.min(img)
        img_max = np.max(img)
        if img_max > img_min:
            img_normalized = (img - img_min) / (img_max - img_min)
        else:
            img_normalized = np.zeros_like(img)
        
        img_binned = np.floor(img_normalized * 31) / 31.0
        return torch.from_numpy(img_binned).unsqueeze(0)

    def _load_mask(self, stem):
        for ext in [".png", ".dcm"]:
            path = os.path.join(self.mask_dir, stem + ext)
            if os.path.exists(path):
                try:
                    if ext == ".png":
                        mask = np.array(Image.open(path).convert("L"), dtype=np.float32)
                        mask = (mask > 127).astype(np.float32)
                    else:
                        dcm = pydicom.dcmread(path, force=True)
                        mask = dcm.pixel_array.astype(np.float32)
                        mask = (mask > 0).astype(np.float32)
                    return torch.from_numpy(mask).unsqueeze(0)
                except Exception as e:
                    continue
        raise FileNotFoundError(f"Mask not found for {stem}")

    def _pad_or_resize(self, img):
        if img.shape[1] != self.target_size[0] or img.shape[2] != self.target_size[1]:
            c, h, w = img.shape
            target_h, target_w = self.target_size
            pad_h = max(target_h - h, 0)
            pad_w = max(target_w - w, 0)
            pad_top, pad_bottom = pad_h // 2, pad_h - pad_h // 2
            pad_left, pad_right = pad_w // 2, pad_w - pad_w // 2
            img = F.pad(img, (pad_left, pad_right, pad_top, pad_bottom), mode='constant', value=0)
            if img.shape[1] > target_h or img.shape[2] > target_w:
                start_h = (img.shape[1] - target_h) // 2
                start_w = (img.shape[2] - target_w) // 2
                img = img[:, start_h:start_h + target_h, start_w:start_w + target_w]
        return img

# ===============================
# FOCAL LOSS
# ===============================
class FocalLoss(nn.Module):
    def __init__(self, alpha=1, gamma=2, reduction='mean'):
        super(FocalLoss, self).__init__()
        self.alpha = alpha
        self.gamma = gamma
        self.reduction = reduction

    def forward(self, inputs, targets):
        BCE_loss = nn.CrossEntropyLoss(reduction='none')(inputs, targets)
        pt = torch.exp(-BCE_loss)
        F_loss = self.alpha * (1 - pt) ** self.gamma * BCE_loss
        if self.reduction == 'mean':
            return F_loss.mean()
        return F_loss

