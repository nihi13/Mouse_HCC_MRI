# VISUALIZATION
# ===============================
def visualize_overlays(model, data_loader, device, epoch, num_images=4, 
                      pixel_spacing=1.0, save_dir=None):
    """Visualize and save overlay predictions"""
    model.eval()
    with torch.no_grad():
        for batch in data_loader:
            val_img_prev = batch["img_prev"].to(device)
            val_img_center = batch["img_center"].to(device)
            val_img_next = batch["img_next"].to(device)
            val_masks = batch["mask"]
            
            val_outputs = model(val_img_prev, val_img_center, val_img_next)
            predicted_masks = torch.argmax(val_outputs, dim=1)

            val_img_center = val_img_center.cpu().numpy()
            val_masks = val_masks.cpu().numpy()
            predicted_masks = predicted_masks.cpu().numpy()

            plt.figure(figsize=(20, num_images * 5))
            for j in range(min(num_images, val_img_center.shape[0])):
                # Measure diameters in mm
                gt_diameters, gt_total = measure_diameter(val_masks[j, 0], pixel_spacing=pixel_spacing)
                pred_diameters, pred_total = measure_diameter(predicted_masks[j], pixel_spacing=pixel_spacing)
                
                plt.subplot(num_images, 4, j * 4 + 1)
                plt.imshow(val_img_center[j, 0], cmap='gray')
                plt.title(f"Original Image {j+1}", fontsize=12)
                plt.axis('off')

                plt.subplot(num_images, 4, j * 4 + 2)
                plt.imshow(val_masks[j, 0], cmap='gray')
                gt_text = f"GT Mask {j+1}\n"
                for i, d in enumerate(gt_diameters, 1):
                    gt_text += f"D{i}: {d:.2f}mm\n"
                gt_text += f"Total: {gt_total:.2f}mm"
                plt.title(gt_text, fontsize=10)
                plt.axis('off')

                plt.subplot(num_images, 4, j * 4 + 3)
                plt.imshow(predicted_masks[j], cmap='gray')
                pred_text = f"Pred Mask {j+1}\n"
                for i, d in enumerate(pred_diameters, 1):
                    pred_text += f"D{i}: {d:.2f}mm\n"
                pred_text += f"Total: {pred_total:.2f}mm"
                plt.title(pred_text, fontsize=10)
                plt.axis('off')

                plt.subplot(num_images, 4, j * 4 + 4)
                overlay_img = np.stack([val_img_center[j, 0]] * 3, axis=-1)
                overlay_img = (overlay_img - overlay_img.min()) / (overlay_img.max() - overlay_img.min() + 1e-8)
                
                red_mask = val_masks[j, 0] > 0.5
                overlay_img[red_mask, 0] = np.minimum(overlay_img[red_mask, 0] + 0.3, 1.0)
                
                green_mask = predicted_masks[j] > 0.5
                overlay_img[green_mask, 1] = np.minimum(overlay_img[green_mask, 1] + 0.3, 1.0)
                
                plt.imshow(overlay_img)
                overlay_text = f"Overlay {j+1}\n(Red: GT, Green: Pred)\n"
                overlay_text += f"GT Total: {gt_total:.2f}mm\n"
                overlay_text += f"Pred Total: {pred_total:.2f}mm"
                plt.title(overlay_text, fontsize=10)
                plt.axis('off')
            
            plt.suptitle(f'Validation Results - Epoch {epoch}', fontsize=16, y=0.98)
            plt.tight_layout()
            
            if save_dir:
                save_path = os.path.join(save_dir, f'overlay_epoch_{epoch:04d}.png')
                plt.savefig(save_path, dpi=150, bbox_inches='tight')
                print(f"   Saved visualization to: {save_path}")
            
            plt.close()
            break

# ===============================
# MAIN EXECUTION
# ===============================
def main():
    print("\n" + "="*70)
    print("CSANet Training with Pretrained Autoencoder Weights")
    print("R50-B16 Architecture with Diameter Measurements")
    print("="*70)
    
    device = config.DEVICE
    print(f"\nDevice: {device}")
    
    # Save configuration
    config_dict = {k: str(v) for k, v in config.__dict__.items() if not k.startswith('_')}
    with open(os.path.join(config.RESULTS_DIR, 'config.json'), 'w') as f:
        json.dump(config_dict, f, indent=4)
    print(f"Configuration saved to: {os.path.join(config.RESULTS_DIR, 'config.json')}")
    
    # Initialize model
    print("\n" + "="*70)
    print("INITIALIZING R50-B16 ARCHITECTURE")
    print("="*70)
    config_model = configs.get_r50_b16_config()
    model = ViT_seg(config_model, img_size=(256, 256), num_classes=config_model.n_classes).to(device)
    print("✓ Model initialized successfully\n")
    
    # Load autoencoder weights
    model = load_autoencoder_weights(model, config.AUTOENCODER_CHECKPOINT, device)
    
    # Augmentations
    train_transforms = Compose([
        RandFlipd(keys=["img_prev", "img_center", "img_next", "mask"], prob=0.5, spatial_axis=1),
        RandGaussianNoised(keys=["img_prev", "img_center", "img_next"], prob=0.5, std=0.01),
        RandGaussianSmoothd(keys=["img_prev", "img_center", "img_next"], prob=0.3, sigma_x=(0.5, 1.0)),
        EnsureTyped(keys=["img_prev", "img_center", "img_next", "mask"]),
        RandHistogramShiftd(keys=["img_prev", "img_center", "img_next"], num_control_points=10, prob=0.5),
        RandAdjustContrastd(keys=["img_prev", "img_center", "img_next"], prob=0.5, gamma=(0.5, 4.5), invert_image=False, retain_stats=False),
    ])
    
    val_transforms = Compose([
        EnsureTyped(keys=["img_prev", "img_center", "img_next", "mask"]),
    ])
    
    # Load datasets
    print("Loading datasets...")
    print("\n[Training Dataset A]")
    train_dataset_A = CSANet25DDataset(config.TRAIN_DICOM_DIR, config.TRAIN_MASK_DIR_A, transforms=train_transforms)
    print("\n[Training Dataset B]")
    train_dataset_B = CSANet25DDataset(config.TRAIN_DICOM_DIR, config.TRAIN_MASK_DIR_B, transforms=train_transforms)
    print("\n[Validation Dataset]")
    val_dataset = CSANet25DDataset(config.VAL_DICOM_DIR, config.VAL_MASK_DIR, transforms=val_transforms)
    
    # Combine datasets
    datasets_to_combine = []
    if len(train_dataset_A) > 0:
        datasets_to_combine.append(train_dataset_A)
        print(f"\n✓ Added Dataset A: {len(train_dataset_A)} samples")
    
    if len(train_dataset_B) > 0:
        datasets_to_combine.append(train_dataset_B)
        print(f"✓ Added Dataset B: {len(train_dataset_B)} samples")
    
    if len(val_dataset) > 0:
        print(f"✓ Validation dataset: {len(val_dataset)} samples")
    
    if len(datasets_to_combine) == 0:
        raise ValueError("\nERROR: No valid training datasets found!")
    
    if len(val_dataset) == 0:
        raise ValueError("\nERROR: Validation dataset is empty!")
    
    train_dataset = datasets_to_combine[0] if len(datasets_to_combine) == 1 else ConcatDataset(datasets_to_combine)
    
    train_loader = DataLoader(train_dataset, batch_size=config.BATCH_SIZE, shuffle=True, num_workers=4)
    val_loader = DataLoader(val_dataset, batch_size=config.BATCH_SIZE, shuffle=False, num_workers=4)
    
    print(f"\n✓ Combined training dataset: {len(train_dataset)} samples")
    print(f"✓ Validation dataset: {len(val_dataset)} samples")
    print(f"✓ Train batches: {len(train_loader)}")
    print(f"✓ Val batches: {len(val_loader)}")
    
    # Train
    train_losses, val_losses, dice_scores = train_csanet(model, train_loader, val_loader, device, config)
    
    # Plot results
    print("\nGenerating training plots...")
    plt.figure(figsize=(15, 5))
    
    plt.subplot(1, 3, 1)
    plt.plot(range(1, len(train_losses) + 1), train_losses, 'b-', label='Training Loss', linewidth=2)
    plt.plot(range(1, len(val_losses) + 1), val_losses, 'r-', label='Validation Loss', linewidth=2)
    plt.xlabel('Epochs')
    plt.ylabel('Loss')
    plt.title('Training & Validation Loss')
    plt.legend()
    plt.grid(True, alpha=0.3)
    
    plt.subplot(1, 3, 2)
    plt.plot(range(1, len(dice_scores) + 1), dice_scores, 'g-', label='Dice Score', linewidth=2)
    plt.axhline(y=max(dice_scores), color='g', linestyle='--', alpha=0.7, label=f'Best: {max(dice_scores):.4f}')
    plt.xlabel('Epochs')
    plt.ylabel('Dice Score')
    plt.title('Dice Score Progress')
    plt.legend()
    plt.grid(True, alpha=0.3)
    plt.ylim([0, 1])
    
    plt.subplot(1, 3, 3)
    plt.scatter(val_losses, dice_scores, alpha=0.6, c=range(len(dice_scores)), cmap='viridis')
    plt.xlabel('Validation Loss')
    plt.ylabel('Dice Score')
    plt.title('Loss vs Dice Score')
    plt.colorbar(label='Epoch')
    plt.grid(True, alpha=0.3)
    
    plt.tight_layout()
    plot_path = os.path.join(config.RESULTS_DIR, 'training_curves.png')
    plt.savefig(plot_path, dpi=150, bbox_inches='tight')
    print(f"✓ Training curves saved to: {plot_path}")
    plt.close()
    
    # Save metrics
    metrics_path = os.path.join(config.RESULTS_DIR, 'metrics')
    os.makedirs(metrics_path, exist_ok=True)
    np.save(os.path.join(metrics_path, "train_losses.npy"), np.array(train_losses))
    np.save(os.path.join(metrics_path, "val_losses.npy"), np.array(val_losses))
    np.save(os.path.join(metrics_path, "dice_scores.npy"), np.array(dice_scores))
    print(f"✓ Metrics saved to: {metrics_path}")
    
    # Final visualization
    print("\nGenerating final prediction visualizations...")
    visualize_overlays(model, val_loader, device, epoch=len(train_losses), 
                      num_images=6, pixel_spacing=config.PIXEL_SPACING,
                      save_dir=config.RESULTS_DIR)
    
    print("\n" + "="*70)
    print("TRAINING PIPELINE COMPLETE!")
    print(f"All results saved to: {config.RESULTS_DIR}")
    print("="*70)

if __name__ == "__main__":
    main()
